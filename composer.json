{
	"name": "hypejunction/hypefaker",
	"type": "elgg-plugin",
	"description": "Generate fake data for your Elgg site",
	"homepage": "http://hypejunction.com",
	"keywords": [
		"elgg",
		"plugin",
		"demo",
		"lorem ipsum"
	],
	"license": "GPL-2.0",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "info@hypejunction.com"
		}
	],
	"extra": {
		"installer-name": "hypeFaker"
	},
	"require": {
		"composer/installers": "^1.0 || ^2.0",
		"php": ">=7.2",
		"elgg/elgg": "^3.0",
		"hypejunction/hypeapps": "*",
		"fzaninotto/faker": "^1.9"
	},
	"autoload": {
		"psr-4": {
			"Hypejunction\\Faker\\": "classes/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	}
}
